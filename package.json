{
  "name": "test-power-automations",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "typecheck:web": "tsc --noEmit",
    "build:web": "npm run typecheck:web && npm run build:web:open-ticket && npm run build:web:config",
    "build:web:open-ticket": "esbuild src/web/ts/open_ticket.ts --bundle --format=iife --outfile=src/web/static/open_ticket.js",
    "build:web:config": "esbuild src/web/ts/config.ts --bundle --format=iife --outfile=src/web/static/config.js"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@microsoft/teams-js": "^2.53.1"
  }
}
